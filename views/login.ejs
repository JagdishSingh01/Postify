<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="antialiased bg-zinc-900 text-gray-100 font-sans">
    
    <div class="w-full min-h-screen flex items-center justify-center bg-zinc-900">
      <form action="/login" method="POST" class="w-full max-w-md mx-4 bg-zinc-800/60 backdrop-blur-sm p-6 rounded-lg shadow-lg space-y-4">
        <h3 class="text-3xl sm:text-4xl font-extrabold text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400 tracking-tight drop-shadow">Login Your Account</h3>
        <input type="email" name="email" placeholder="Email" class="w-full p-3 bg-zinc-700/50 placeholder-zinc-400 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <input type="password" name="password" placeholder="Password" class="w-full p-3 bg-zinc-700/50 placeholder-zinc-400 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 active:scale-95 transition-transform rounded-md p-3 text-white font-semibold">Login</button>
        <a href="/" class="block text-center text-blue-400 hover:text-blue-500 transition-colors">Don't have an account? Register</a>
      </form>

    </div>

  </body>
</html>